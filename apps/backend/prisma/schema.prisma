generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Role {
  id          String     @id @default(uuid())
  name        String     @unique
  description String?
  permissions String[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  users       UserRole[]
}

model UserRole {
  id        String   @id @default(uuid())
  userId    String
  roleId    String
  createdAt DateTime @default(now())
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  password      String
  firstName     String
  lastName      String
  phone         String?
  isActive      Boolean        @default(true)
  avatar        String?
  resetToken    String?
  resetTokenExp DateTime?
  refreshToken  String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  role          String         @default("enthusiasts")
  auditLogs     AuditLog[]
  notifications Notification[]
  roles         UserRole[]
  events        Event[]
  registrations Registration[]
}

model Event {
  id                   String               @id @default(uuid()) @map("event_id")
  title                String
  category             String?
  description          String?              @map("full_description")
  shortDescription     String?              @map("short_description")
  posterImage          String?              @map("banner_url")
  venue                String?
  mode                 String?
  capacity             Int?                 @map("max_capacity")
  date                 DateTime?            @map("start_datetime")
  time                 String?
  registrationDeadline DateTime?            @map("registration_deadline")
  status               String               @default("DRAFT") @map("event_status")
  registrationFormType RegistrationFormType @default(DEFAULT) @map("registration_form_type")
  organizerId          String?              @map("organizer_id")
  createdAt            DateTime             @default(now()) @map("created_at")
  updatedAt            DateTime             @updatedAt @map("updated_at")
  endDatetime          DateTime?            @map("end_datetime")
  meetingLink          String?              @map("meeting_link")
  agendaJson           Json?                @map("agenda")
  speakerDetailsJson   Json?                @map("speaker_details")
  announcements        Announcement[]
  agenda               EventAgenda[]
  speakers             EventSpeaker[]
  crewTasks            CrewTask[]
  organizer            User?                @relation(fields: [organizerId], references: [id], onDelete: Cascade)
  formFields           FormField[]
  incidents            Incident[]
  registrations        Registration[]
  tickets              Ticket[]

  @@index([status])
  @@index([organizerId])
  @@index([createdAt])
  @@map("events")
}

model EventAgenda {
  id        String   @id @default(uuid())
  eventId   String
  title     String
  speaker   String?
  startTime String
  endTime   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model EventSpeaker {
  id           String   @id @default(uuid())
  eventId      String
  name         String
  role         String?
  organization String?
  bio          String?
  photo        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  event        Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model FormField {
  id         String    @id @default(uuid()) @map("field_id")
  eventId    String    @map("event_id")
  label      String    @map("field_label")
  type       String    @map("field_type")
  isRequired Boolean   @default(false) @map("is_required")
  fieldOrder Int       @map("field_order")
  options    Json?     @map("select_options")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime? @default(now()) @map("updated_at")
  event      Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("form_fields")
}

model Registration {
  id               String               @id @default(uuid()) @map("registration_id")
  userId           String               @map("user_id")
  eventId          String               @map("event_id")
  registrationDate DateTime             @default(now()) @map("registration_date")
  status           String               @default("CONFIRMED") @map("registration_status")
  name             String?              @map("name")
  roll_number      String?              @map("roll_number")
  email            String?              @map("email")
  department       String?              @map("department")
  createdAt        DateTime             @default(now()) @map("created_at")
  updatedAt        DateTime?            @default(now()) @map("updated_at")
  emailSent        Boolean?             @default(false) @map("email_sent")
  responses        Json?                @map("responses")
  answers          RegistrationAnswer[]
  event            Event                @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user             User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  ticket           Ticket?

  @@unique([userId, eventId])
  @@index([status])
  @@index([eventId])
  @@index([userId])
  @@index([registrationDate])
  @@map("registrations")
}

model RegistrationAnswer {
  id             String       @id @default(uuid())
  registrationId String
  fieldId        String
  value          Json
  createdAt      DateTime     @default(now())
  registration   Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
}

model Ticket {
  id               String          @id @default(uuid()) @map("ticket_id")
  registrationId   String          @unique @map("registration_id")
  eventId          String          @map("event_id")
  ticketCode       String          @unique @map("ticket_code")
  qrCodeUrl        String?         @map("qr_code_url")
  status           String          @default("ACTIVE") @map("ticket_status")
  scannedAt        DateTime?       @map("scanned_at")
  scannerId        String?         @map("scanner_id")
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime?       @default(now()) @map("updated_at")
  eventTitle       String?         @map("event_title")
  eventDate        String?         @map("event_date")
  eventTime        String?         @map("event_time")
  eventVenue       String?         @map("event_venue")
  userName         String?         @map("user_name")
  userRoll         String?         @map("user_roll")
  userEmail        String?         @map("user_email")
  attendanceStatus String?         @map("attendance_status")
  attendance       AttendanceLog[]
  event            Event           @relation(fields: [eventId], references: [id], onDelete: Cascade)
  registration     Registration    @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([eventId])
  @@index([createdAt])
  @@map("tickets")
}

model AttendanceLog {
  id        String   @id @default(uuid())
  ticketId  String
  userId    String
  eventId   String
  scannedAt DateTime @default(now())
  scannerId String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@index([scannedAt])
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  title     String
  message   String
  type      NotificationType
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  oldValues Json?
  newValues Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])
}

model Announcement {
  id        String   @id @default(uuid())
  eventId   String
  title     String
  message   String
  type      String   @default("UPDATE")
  sendEmail Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model SchemaEnumDummy {
  id        String             @id
  status    EventStatus
  mode      EventMode
  tStatus   TicketStatus
  rStatus   RegistrationStatus
  fieldType FieldType
}

model CrewTask {
  id          String   @id @default(uuid())
  eventId     String
  title       String
  description String?
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("crew_tasks")
}

model Incident {
  id            String   @id @default(uuid())
  eventId       String
  title         String
  description   String
  priority      String
  attachmentUrl String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  event         Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("incidents")
}

model NewsArticle {
  id          String        @id @default(uuid()) @db.Uuid
  title       String
  description String?
  fullContent String?       @map("full_content")
  aiSummary   String?       @map("ai_summary")
  imageUrl    String?       @map("image_url")
  sourceName  String        @map("source_name")
  sourceUrl   String        @map("source_url")
  articleUrl  String        @unique @map("article_url")
  category    NewsCategory?
  publishedAt DateTime?     @map("published_at")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  isActive    Boolean       @default(true) @map("is_active")

  @@index([isActive, publishedAt])
  @@index([category])
  @@index([createdAt])
  @@map("news_articles")
}

model IngestionRun {
  id           String    @id @default(uuid()) @db.Uuid
  startedAt    DateTime  @map("started_at")
  completedAt  DateTime? @map("completed_at")
  durationMs   Int?      @map("duration_ms")
  fetched      Int       @default(0)
  deduplicated Int       @default(0)
  persisted    Int       @default(0)
  status       String
  errorMessage String?   @map("error_message")
  createdAt    DateTime  @default(now()) @map("created_at")

  @@index([createdAt])
  @@index([status])
  @@map("ingestion_runs")
}

enum RegistrationFormType {
  DEFAULT
  CUSTOM
}

enum RoleName {
  SUPER_ADMIN
  ADMIN
  ORGANIZER
  VOLUNTEER
  SCANNER
  ENTHUSIAST
}

enum EventStatus {
  DRAFT
  PUBLISHED
  REGISTRATION_OPEN
  REGISTRATION_CLOSED
  ONGOING
  COMPLETED
  ARCHIVED
}

enum EventMode {
  ONLINE
  OFFLINE
  HYBRID
}

enum RegistrationStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum TicketStatus {
  ACTIVE
  USED
  CANCELLED
}

enum NotificationType {
  REGISTRATION_SUCCESS
  TICKET_GENERATED
  EVENT_REMINDER
  EVENT_UPDATE
}

enum FieldType {
  TEXT
  EMAIL
  PHONE
  NUMBER
  DROPDOWN
  RADIO
  CHECKBOX
  TEXTAREA
}

enum NewsCategory {
  AWS
  AZURE
  GCP
  CLOUD
  AI
  DEVOPS
  CYBERSECURITY
  PROGRAMMING
  GENERAL
}

model UnhandledQuery {
  id             String    @id @default(uuid())
  sessionId      String    @map("session_id")
  message        String
  bestSimilarity Float     @map("best_similarity")
  bestMatchDoc   String?   @map("best_match_doc")
  timestamp      DateTime  @default(now())
  status         String    @default("live")
  adminReply     String?   @map("admin_reply")
  adminDocId     String?   @map("admin_doc_id")
  resolvedAt     DateTime? @map("resolved_at")

  @@map("unhandled_queries")
}

model FaqChip {
  id        String   @id @default(uuid())
  question  String
  answer    String   @default("")
  orderIdx  Int      @default(0) @map("order_idx")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("faq_chips")
}

model CrewMessage {
  id         String   @id @default(uuid())
  chatId     String   @map("chat_id")
  sender     String
  ciphertext String
  iv         String
  timestamp  DateTime @default(now())
  status     String   @default("delivered")

  @@map("crew_messages")
}

model GroupChatMessage {
  id             String   @id @default(uuid())
  senderName     String   @map("sender_name")
  senderRole     String   @map("sender_role")
  avatarColor    String   @default("#FF9900") @map("avatar_color")
  avatarInitials String   @map("avatar_initials")
  avatarPhoto    String?  @map("avatar_photo")
  text           String   @default("")
  attachments    Json?    @map("attachments")
  timestamp      DateTime @default(now())

  @@map("group_chat_messages")
}

model Certification {
  id          String   @id @default(uuid())
  key         String   @unique
  name        String
  level       String
  category    String
  summary     String
  highlights  String
  accent      String
  duration    String
  questions   Int
  cost        String
  mode        String
  intended    String?
  domains     Json     // Stores array of Domain: { title, pct, topics: string[] }
  detailHtml  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("certifications")
}

model ReportEvent {
  id           Int                 @id @default(autoincrement())
  eventName    String              @map("event_name")
  eventNumber  Int                 @map("event_number")
  academicYear String              @map("academic_year")
  place        String
  time         String
  createdAt    DateTime            @default(now()) @map("created_at")
  agendaItems  ReportAgendaItem[]
  participants ReportParticipant[]

  @@map("report_events")
}

model ReportAgendaItem {
  id      Int         @id @default(autoincrement())
  eventId Int         @map("event_id")
  content String
  order   Int
  event   ReportEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("report_agenda_items")
}

model ReportParticipant {
  id      Int         @id @default(autoincrement())
  eventId Int         @map("event_id")
  name    String
  role    String
  event   ReportEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("report_participants")
}

// =============================================
// AWS SERVICES CATALOG MODELS
// =============================================

model AWSServiceCategory {
  id           String       @id @default(cuid())
  name         String
  slug         String       @unique
  description  String?
  iconUrl      String?
  displayOrder Int          @default(0)
  isActive     Boolean      @default(true)
  isDeleted    Boolean      @default(false)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  services     AWSService[]

  @@index([displayOrder])
  @@index([isDeleted])
}

model AWSService {
  id                  String             @id @default(cuid())
  serviceCode         String             @unique
  name                String             @unique
  slug                String             @unique
  categoryId          String
  category            AWSServiceCategory @relation(fields: [categoryId], references: [id])
  shortDescription    String
  fullDescription     String
  characteristics     String[]
  features            String[]
  useCases            String[]
  pricingModels       String[]
  relatedServices     Json               // [{"slug": "amazon-ebs", "name": "Amazon EBS"}]
  iconUrl             String
  keywords            String[]
  awsDocumentationUrl String?
  isFeatured          Boolean            @default(false)
  status              String             @default("GA") // GA, Preview, Beta, Deprecated, Retired
  lastAwsUpdate       DateTime?
  comparisonTags      String[]
  displayOrder        Int                @default(0)
  isActive            Boolean            @default(true)
  isDeleted           Boolean            @default(false)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  @@index([categoryId])
  @@index([displayOrder])
  @@index([isDeleted])
  @@index([isFeatured])
}

model Category {
  id           String   @id @default(cuid())
  name         String   @unique
  slug         String   @unique
  flag         String
  displayOrder Int      @default(0)
  isActive     Boolean  @default(true)
  isDeleted    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  regions      Region[]

  @@index([displayOrder])
  @@index([isDeleted])
}

model Region {
  id                        String   @id @default(cuid())
  awsRegionCode             String   @unique
  name                      String
  regionCode                String
  flag                      String
  flagUrl                   String?
  displayOrder              Int      @default(0)
  latitude                  Float
  longitude                 Float
  infrastructureDescription String
  availabilityZones         Int
  launchYear                Int
  primaryLocation           String
  compliance                String
  totalServices             String
  aimlServices              String
  analyticsServices         String
  networkingServices        String
  edgeLocations             String
  directConnect             String
  reach                     String
  latency                   String

  // Relationships
  categoryId                String
  category                  Category @relation(fields: [categoryId], references: [id])
  services                  RegionService[]
  benefits                  RegionBenefit[]
  aiCapabilities            RegionAiCapability[]
  topServices               RegionTopService[]
  workloads                 RegionWorkload[]

  // Soft deletion
  isDeleted                 Boolean  @default(false)

  // Audit fields
  createdBy                 String?
  updatedBy                 String?

  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  @@index([awsRegionCode])
  @@index([categoryId])
  @@index([isDeleted])
}

model RegionService {
  id       String @id @default(cuid())
  name     String
  regionId String
  region   Region @relation(fields: [regionId], references: [id], onDelete: Cascade)

  @@unique([regionId, name])
}

model RegionBenefit {
  id          String @id @default(cuid())
  description String
  regionId    String
  region      Region @relation(fields: [regionId], references: [id], onDelete: Cascade)

  @@unique([regionId, description])
}

model RegionAiCapability {
  id         String @id @default(cuid())
  capability String
  regionId   String
  region     Region @relation(fields: [regionId], references: [id], onDelete: Cascade)

  @@unique([regionId, capability])
}

model RegionTopService {
  id       String @id @default(cuid())
  name     String
  regionId String
  region   Region @relation(fields: [regionId], references: [id], onDelete: Cascade)

  @@unique([regionId, name])
}

model RegionWorkload {
  id          String @id @default(cuid())
  description String
  regionId    String
  region      Region @relation(fields: [regionId], references: [id], onDelete: Cascade)

  @@unique([regionId, description])
}

